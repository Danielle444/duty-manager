# Supabase Postgres connection strings.
# In your Supabase project: Project Settings -> Database -> Connection string.
#
# DATABASE_URL: the "Transaction" pooler connection (port 6543, pgbouncer) - used by the app at runtime.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: the "Session"/direct connection (port 5432, no pgbouncer) - used only for running migrations.
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].pooler.supabase.com:5432/postgres"

# NextAuth (Auth.js) v5 - Google OAuth for /admin.
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# From Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID.
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google (dev)
# and https://<your-domain>/api/auth/callback/google (production).
AUTH_GOOGLE_ID="replace-with-google-oauth-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-oauth-client-secret"

# Supabase Storage - used only server-side to store/serve the course booklet
# PDF (private bucket "course-booklets", short-lived signed URLs). Both
# values are from: Supabase project -> Project Settings -> API.
# SUPABASE_SERVICE_ROLE_KEY bypasses RLS - never expose it to the browser or
# prefix it with NEXT_PUBLIC_. If unset, the course booklet feature degrades
# gracefully (shows "not available") instead of breaking the app.
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"

# Web Push (VAPID) - used for real push notifications to trainees when a new
# message/task is sent (see lib/actions/push.ts). Generate a key pair with:
# npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is safe to expose (used client-side to
# subscribe). VAPID_PRIVATE_KEY must never be exposed to the client or
# prefixed with NEXT_PUBLIC_. VAPID_SUBJECT is a contact mailto: required by
# the Web Push protocol.
NEXT_PUBLIC_VAPID_PUBLIC_KEY="replace-with-vapid-public-key"
VAPID_PRIVATE_KEY="replace-with-vapid-private-key"
VAPID_SUBJECT="mailto:you@example.com"
