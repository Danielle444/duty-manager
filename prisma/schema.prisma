// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  fullName       String
  groupName      String?
  subgroupNumber Int?
  identityNumber String   @unique
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Horse assignment (Stage A - simple name fields only, no separate Horse
  // table): hasPrivateHorse=true -> privateHorseName is the horse shown;
  // otherwise assignedHorseName is the course-assigned horse, if any.
  hasPrivateHorse   Boolean @default(false)
  privateHorseName  String?
  assignedHorseName String?

  availability          StudentAvailability[]
  assignments           DutyAssignment[]
  messageTaskRecipients MessageTaskRecipient[]
  attendance            StudentAttendance[]
  ridingLessonNotes     RidingLessonNote[]

  @@map("students")
}

enum HorseMealType {
  MORNING
  LUNCH
  EVENING
}

// A horse's per-meal feeding instructions. There is still no separate Horse
// table (Student.assignedHorseName/privateHorseName remain the only horse
// identity in this app) - horseName is the natural key here too, matching
// that same existing convention, rather than introducing a full Horse
// entity just for this. LUNCH rows are optional - a horse with only
// MORNING/EVENING rows simply has no lunch feeding. hayType/concentrateType/
// concentrateAmount are all free text on purpose (never an enum, never
// numeric) - amounts like "1/4" or "חופן" don't fit a number column, and
// hay/concentrate types are meant to grow from whatever admins actually type
// (see getKnownHayTypes/getKnownConcentrateTypes), not a fixed list.
model HorseFeedingMeal {
  id                String        @id @default(cuid())
  horseName         String
  mealType          HorseMealType
  hayType           String?
  concentrateType   String?
  concentrateAmount String?
  notes             String?
  updatedByName     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([horseName, mealType])
  @@map("horse_feeding_meals")
}

model StudentAvailability {
  id          String   @id @default(cuid())
  studentId   String
  date        DateTime @db.Date
  isAvailable Boolean

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([date])
  @@map("student_availability")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  PARTIAL
}

// Actual presence at the course day - separate from StudentAvailability
// (planned availability used before duty scheduling) and from
// DutyAssignment.isCompleted (whether an assigned duty shift was carried
// out). A missing row for a student/date means "not yet marked" - never
// inferred as PRESENT or ABSENT.
model StudentAttendance {
  id            String           @id @default(cuid())
  studentId     String
  date          DateTime         @db.Date
  status        AttendanceStatus
  // "HH:MM" - set for PARTIAL when arrival is later than the day's normal
  // start (late arrival) and/or departure is earlier than normal (early
  // departure); both independently nullable.
  arrivalTime   String?
  departureTime String?
  notes         String?
  // Denormalized: admin's name/email or instructor's fullName, whoever last
  // saved this row.
  updatedByName String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([date])
  @@map("student_attendance")
}

enum AllocationMode {
  FIXED_COUNT
  ONE_PER_SUBGROUP
}

model DutyType {
  id                   String         @id @default(cuid())
  name                 String
  description          String?
  defaultRequiredCount Int            @default(1)
  allocationMode       AllocationMode @default(FIXED_COUNT)
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  assignments DutyAssignment[]
  constraints DutyConstraint[]

  @@map("duty_types")
}

model DutyAssignment {
  id          String    @id @default(cuid())
  date        DateTime  @db.Date
  studentId   String
  dutyTypeId  String
  isManual    Boolean   @default(false)
  isPublished Boolean   @default(false)
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  dutyType DutyType @relation(fields: [dutyTypeId], references: [id], onDelete: Cascade)

  // A student can only have one duty per day
  @@unique([date, studentId])
  @@index([date])
  @@index([dutyTypeId])
  @@map("duty_assignments")
}

// Singleton row (id is always 1) holding the course date range
model CourseSettings {
  id        Int      @id @default(1)
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  updatedAt DateTime @updatedAt

  @@map("course_settings")
}

model AvailabilityRangePreset {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("availability_range_presets")
}

// One row per course date, recording which group rides in each of the 4 daily slots
model CourseDayPlan {
  id                    String   @id @default(cuid())
  date                  DateTime @unique @db.Date
  firstMorningGroup     String?
  secondMorningGroup    String?
  firstAfterLunchGroup  String?
  secondAfterLunchGroup String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("course_day_plans")
}

enum CourseSlot {
  FIRST_MORNING
  SECOND_MORNING
  FIRST_AFTER_LUNCH
  SECOND_AFTER_LUNCH
}

// A generic "this duty type blocks whichever group is in this CourseDayPlan slot" rule
model DutyConstraint {
  id         String     @id @default(cuid())
  dutyTypeId String
  slot       CourseSlot
  note       String?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  dutyType DutyType @relation(fields: [dutyTypeId], references: [id], onDelete: Cascade)

  @@index([dutyTypeId])
  @@map("duty_constraints")
}

model Instructor {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  fullName       String
  identityNumber String   @unique
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Stage A: field exists but nothing grants/uses edit access yet - every
  // instructor is still view-only on the horse assignment tab this stage.
  canEditHorseAssignments Boolean @default(false)

  // Grants permission to send messages/tasks to students from the instructor
  // app; false by default so sending stays admin-only until explicitly granted.
  canSendMessages Boolean @default(false)

  // Grants permission to edit StudentAttendance from the instructor app;
  // false by default so editing stays admin-only until explicitly granted.
  // All instructors can still view attendance regardless of this flag.
  canEditAttendance Boolean @default(false)

  // Grants permission to edit RidingLessonNote (notes + ratings) from the
  // instructor app; false by default. Blanket permission - not scoped to
  // only the riding slots this instructor is assigned to. All instructors
  // can still view riding slots/assignments regardless of this flag.
  canEditRidingNotes Boolean @default(false)

  // Grants permission to edit HorseFeedingMeal from the instructor app;
  // false by default. Independent of canEditHorseAssignments - editing who
  // rides which horse and editing that horse's feeding instructions are
  // different trust levels. All instructors can still view feeding
  // instructions regardless of this flag.
  canEditHorseFeeding Boolean @default(false)

  ridingSlotAssignments RidingSlotAssignment[]

  @@map("instructors")
}

model AdminEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_emails")
}

model WeeklySchedule {
  id               String   @id @default(cuid())
  name             String
  startDate        DateTime @db.Date
  endDate          DateTime @db.Date
  uploadedFileName String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items ScheduleItem[]

  @@index([startDate, endDate])
  @@map("weekly_schedules")
}

// Presence of a row for a date = that date is marked "אין תורנויות ביום זה" -
// the scheduler skips automatic duty generation for it. The course schedule
// itself (ScheduleItem) is unaffected; this only concerns duty generation.
model NoDutyDate {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("no_duty_dates")
}

// Singleton row (id is always 1) tracking the one current course booklet
// PDF. The actual file lives in Supabase Storage (private bucket) at
// storagePath - this row is just metadata, never the file itself.
model CourseBooklet {
  id          Int      @id @default(1)
  fileName    String
  storagePath String
  uploadedAt  DateTime @default(now())
  uploadedBy  String?
  updatedAt   DateTime @updatedAt

  @@map("course_booklet")
}

model ScheduleItem {
  id               String   @id @default(cuid())
  weeklyScheduleId String
  date             DateTime @db.Date
  startTime        String
  endTime          String
  title            String
  description      String?
  groupName        String?
  instructorName   String?
  location         String?
  rawText          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  weeklySchedule WeeklySchedule          @relation(fields: [weeklyScheduleId], references: [id], onDelete: Cascade)
  ridingSlot     RidingSlot?
  ridingSlotLink RidingSlotScheduleItem?

  @@index([date])
  @@map("schedule_items")
}

// Presence of a row = this ScheduleItem is a riding slot - never a field on
// ScheduleItem itself, and never inferred from title/description text (that
// stays a UI-only suggestion elsewhere). Deleting the ScheduleItem cascades
// here, taking its assignments/notes with it.
model RidingSlot {
  id                       String   @id @default(cuid())
  scheduleItemId           String   @unique
  // Deferred to a later stage - default false (hidden) until student
  // visibility is deliberately implemented and enabled per slot.
  showInstructorToStudents Boolean  @default(false)
  showArenaToStudents      Boolean  @default(false)
  showSubgroupToStudents   Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  scheduleItem  ScheduleItem             @relation(fields: [scheduleItemId], references: [id], onDelete: Cascade)
  assignments   RidingSlotAssignment[]
  notes         RidingLessonNote[]
  scheduleItems RidingSlotScheduleItem[]

  @@map("riding_slots")
}

// A logical riding slot can span more than one real ScheduleItem row (e.g. a
// 2-hour lesson stored as two contiguous 1-hour Excel rows, coalesced into
// one display card) - this records every real row a RidingSlot covers,
// including its own anchor row (RidingSlot.scheduleItemId), so instructor
// views/student visibility (later stages) can resolve the full lesson
// instead of only the anchor. One real row belongs to at most one riding
// slot (scheduleItemId unique).
model RidingSlotScheduleItem {
  id             String @id @default(cuid())
  ridingSlotId   String
  scheduleItemId String @unique

  ridingSlot   RidingSlot   @relation(fields: [ridingSlotId], references: [id], onDelete: Cascade)
  scheduleItem ScheduleItem @relation(fields: [scheduleItemId], references: [id], onDelete: Cascade)

  @@unique([ridingSlotId, scheduleItemId])
  @@map("riding_slot_schedule_items")
}

// One row per group/subgroup split within a slot. groupName/subgroupNumber
// both null = applies to the whole slot (no split needed) - a slot with
// different instructors/arenas per subgroup gets one row per split instead.
model RidingSlotAssignment {
  id             String   @id @default(cuid())
  ridingSlotId   String
  groupName      String?
  subgroupNumber Int?
  instructorId   String?
  arena          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ridingSlot RidingSlot  @relation(fields: [ridingSlotId], references: [id], onDelete: Cascade)
  instructor Instructor? @relation(fields: [instructorId], references: [id])

  @@unique([ridingSlotId, groupName, subgroupNumber])
  @@map("riding_slot_assignments")
}

// One row per student per riding slot - a missing row means no note/rating
// entered yet, not a zero/blank rating. Single shared note field (no
// separate admin/instructor tracks) and no history: each save overwrites
// the previous value, same upsert convention as StudentAttendance.
model RidingLessonNote {
  id               String   @id @default(cuid())
  ridingSlotId     String
  studentId        String
  note             String?
  // 1.0-5.0 in 0.5 steps, stored as half-points (2-10) - validated in the
  // action layer, not the schema.
  ratingHalfPoints Int?
  // Overrides the student's normal horse (getHorseDisplayInfo) for display
  // in this specific riding session only - never written back to
  // Student.assignedHorseName/privateHorseName, and has no effect outside
  // this one row.
  sessionHorseName String?
  updatedByName    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ridingSlot RidingSlot @relation(fields: [ridingSlotId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([ridingSlotId, studentId])
  @@map("riding_lesson_notes")
}

enum MessageTaskType {
  MESSAGE
  TASK
}

enum MessageAudience {
  ALL
  GROUP
  SPECIFIC
}

// Recipients are materialized into MessageTaskRecipient rows at send time -
// audience/groupName here are kept only for the admin's own display of what
// was sent, they are never re-queried to determine current recipients.
model MessageTask {
  id            String          @id @default(cuid())
  type          MessageTaskType
  title         String
  body          String
  audience      MessageAudience
  groupName     String?
  createdByName String?
  isArchived    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  recipients MessageTaskRecipient[]

  @@map("message_tasks")
}

model MessageTaskRecipient {
  id            String    @id @default(cuid())
  messageTaskId String
  studentId     String
  readAt        DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  messageTask MessageTask @relation(fields: [messageTaskId], references: [id], onDelete: Cascade)
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([messageTaskId, studentId])
  @@index([studentId])
  @@map("message_task_recipients")
}

enum CourseMaterialType {
  FILE
  LINK
}

enum CourseMaterialVisibility {
  STUDENTS
  INSTRUCTORS
  BOTH
}

// Separate from CourseBooklet on purpose - this supports many rows, each
// with its own storage path, unlike the booklet's singleton fixed-path file.
model CourseMaterial {
  id           String                   @id @default(cuid())
  title        String
  description  String?
  materialType CourseMaterialType
  visibility   CourseMaterialVisibility
  filePath     String?
  fileName     String?
  externalUrl  String?
  isActive     Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@map("course_materials")
}

enum NotificationType {
  ATTENDANCE_MARKED
  MATERIAL_ADDED
}

enum NotificationRecipientRole {
  STUDENT
  INSTRUCTOR
}

// Automatic, system-generated in-app notifications only - deliberately
// separate from MessageTask/MessageTaskRecipient, which stay exactly as they
// are and continue to handle admin/instructor-authored messages and tasks.
// One row per (event, recipient) - studentId is set when recipientRole is
// STUDENT, instructorId when INSTRUCTOR (never both). relatedId is a loose
// pointer to the source row (e.g. a StudentAttendance.id or
// CourseMaterial.id) for a future "open" deep-link - not a real FK, since the
// source table differs by type.
model Notification {
  id            String                    @id @default(cuid())
  type          NotificationType
  title         String
  body          String?
  recipientRole NotificationRecipientRole
  studentId     String?
  instructorId  String?
  relatedId     String?
  readAt        DateTime?
  createdAt     DateTime                  @default(now())

  @@index([studentId])
  @@index([instructorId])
  @@map("notifications")
}
