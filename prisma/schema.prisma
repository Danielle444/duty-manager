// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  fullName       String
  groupName      String?
  subgroupNumber Int?
  identityNumber String   @unique
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Horse assignment (Stage A - simple name fields only, no separate Horse
  // table): hasPrivateHorse=true -> privateHorseName is the horse shown;
  // otherwise assignedHorseName is the course-assigned horse, if any.
  hasPrivateHorse   Boolean @default(false)
  privateHorseName  String?
  assignedHorseName String?

  availability            StudentAvailability[]
  assignments             DutyAssignment[]
  messageTaskRecipients   MessageTaskRecipient[]
  attendance              StudentAttendance[]
  ridingLessonNotes       RidingLessonNote[]
  ridingLessonNotesTaught RidingLessonNoteTaughtStudent[]
  weeklyFeedbackResponses WeeklyFeedbackResponse[]
  ridingProgressFeedback  StudentRidingProgressFeedback[]
  lungeProgressFeedback   StudentLungeProgressFeedback[]

  teachingPracticeTrackMemberships TeachingPracticeTrackTrainee[]
  teachingPracticeParticipations   TeachingPracticeParticipant[]

  @@map("students")
}

enum HorseMealType {
  MORNING
  LUNCH
  EVENING
}

// A horse's per-meal feeding instructions. There is still no separate Horse
// table (Student.assignedHorseName/privateHorseName remain the only horse
// identity in this app) - horseName is the natural key here too, matching
// that same existing convention, rather than introducing a full Horse
// entity just for this. LUNCH rows are optional - a horse with only
// MORNING/EVENING rows simply has no lunch feeding. hayType/concentrateType/
// concentrateAmount are all free text on purpose (never an enum, never
// numeric) - amounts like "1/4" or "חופן" don't fit a number column, and
// hay/concentrate types are meant to grow from whatever admins actually type
// (see getKnownHayTypes/getKnownConcentrateTypes), not a fixed list.
model HorseFeedingMeal {
  id                String        @id @default(cuid())
  horseName         String
  mealType          HorseMealType
  hayType           String?
  concentrateType   String?
  concentrateAmount String?
  notes             String?
  updatedByName     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([horseName, mealType])
  @@map("horse_feeding_meals")
}

model StudentAvailability {
  id          String   @id @default(cuid())
  studentId   String
  date        DateTime @db.Date
  isAvailable Boolean

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([date])
  @@map("student_availability")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  PARTIAL
}

// Actual presence at the course day - separate from StudentAvailability
// (planned availability used before duty scheduling) and from
// DutyAssignment.isCompleted (whether an assigned duty shift was carried
// out). A missing row for a student/date means "not yet marked" - never
// inferred as PRESENT or ABSENT.
model StudentAttendance {
  id            String           @id @default(cuid())
  studentId     String
  date          DateTime         @db.Date
  status        AttendanceStatus
  // "HH:MM" - set for PARTIAL when arrival is later than the day's normal
  // start (late arrival) and/or departure is earlier than normal (early
  // departure); both independently nullable.
  arrivalTime   String?
  departureTime String?
  notes         String?
  // Denormalized: admin's name/email or instructor's fullName, whoever last
  // saved this row.
  updatedByName String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([date])
  @@map("student_attendance")
}

enum AllocationMode {
  FIXED_COUNT
  ONE_PER_SUBGROUP
}

model DutyType {
  id                   String         @id @default(cuid())
  name                 String
  description          String?
  defaultRequiredCount Int            @default(1)
  allocationMode       AllocationMode @default(FIXED_COUNT)
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  assignments DutyAssignment[]
  constraints DutyConstraint[]

  @@map("duty_types")
}

model DutyAssignment {
  id          String    @id @default(cuid())
  date        DateTime  @db.Date
  studentId   String
  dutyTypeId  String
  isManual    Boolean   @default(false)
  isPublished Boolean   @default(false)
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  dutyType DutyType @relation(fields: [dutyTypeId], references: [id], onDelete: Cascade)

  // A student can only have one duty per day
  @@unique([date, studentId])
  @@index([date])
  @@index([dutyTypeId])
  @@map("duty_assignments")
}

// Singleton row (id is always 1) holding the course date range
model CourseSettings {
  id        Int      @id @default(1)
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  updatedAt DateTime @updatedAt

  @@map("course_settings")
}

model AvailabilityRangePreset {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("availability_range_presets")
}

// One row per course date, recording which group rides in each of the 4 daily slots
model CourseDayPlan {
  id                    String   @id @default(cuid())
  date                  DateTime @unique @db.Date
  firstMorningGroup     String?
  secondMorningGroup    String?
  firstAfterLunchGroup  String?
  secondAfterLunchGroup String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("course_day_plans")
}

enum CourseSlot {
  FIRST_MORNING
  SECOND_MORNING
  FIRST_AFTER_LUNCH
  SECOND_AFTER_LUNCH
}

// A generic "this duty type blocks whichever group is in this CourseDayPlan slot" rule
model DutyConstraint {
  id         String     @id @default(cuid())
  dutyTypeId String
  slot       CourseSlot
  note       String?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  dutyType DutyType @relation(fields: [dutyTypeId], references: [id], onDelete: Cascade)

  @@index([dutyTypeId])
  @@map("duty_constraints")
}

model Instructor {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  fullName       String
  identityNumber String   @unique
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Stage A: field exists but nothing grants/uses edit access yet - every
  // instructor is still view-only on the horse assignment tab this stage.
  canEditHorseAssignments Boolean @default(false)

  // Grants permission to send messages/tasks to students from the instructor
  // app; false by default so sending stays admin-only until explicitly granted.
  canSendMessages Boolean @default(false)

  // Grants permission to edit StudentAttendance from the instructor app;
  // false by default so editing stays admin-only until explicitly granted.
  // All instructors can still view attendance regardless of this flag.
  canEditAttendance Boolean @default(false)

  // Grants permission to edit RidingLessonNote (notes + ratings) from the
  // instructor app; false by default. Blanket permission - not scoped to
  // only the riding slots this instructor is assigned to. All instructors
  // can still view riding slots/assignments regardless of this flag.
  canEditRidingNotes Boolean @default(false)

  // Grants permission to edit HorseFeedingMeal from the instructor app;
  // false by default. Independent of canEditHorseAssignments - editing who
  // rides which horse and editing that horse's feeding instructions are
  // different trust levels. All instructors can still view feeding
  // instructions regardless of this flag.
  canEditHorseFeeding Boolean @default(false)

  // Grants permission to manage Teaching Practice tracks/lessons/participant
  // roles/child assignments (who's teaching whom, when) from the instructor
  // app; false by default. All instructors can still view the full teaching
  // practice schedule regardless of this flag.
  canManageTeachingPracticeAssignments Boolean @default(false)

  // Grants permission to edit Teaching Practice horse/equipment fields
  // specifically; false by default. Independent of
  // canManageTeachingPracticeAssignments - same trust-level split as
  // canEditHorseAssignments vs canEditHorseFeeding above.
  canManageTeachingPracticeHorses Boolean @default(false)

  // Grants permission to write/edit TeachingPracticeFeedback; false by
  // default. All instructors can still view the schedule regardless of this
  // flag; feedback content itself stays admin/authorized-instructor-only.
  canEditTeachingPracticeFeedback Boolean @default(false)

  // Grants permission to collect/manage parent digital-signature consent
  // forms for Teaching Practice children (the ranch-tablet flow); false by
  // default. Independent of canManageTeachingPracticeAssignments/Horses -
  // collecting legal consent/medical data is a different trust level than
  // scheduling. Intended for a dedicated tablet Instructor account, not a
  // capability granted to every instructor.
  canManageChildSignatures Boolean @default(false)

  ridingSlotAssignments           RidingSlotAssignment[]
  ridingSlotAssignmentInstructors RidingSlotAssignmentInstructor[]

  teachingPracticeTracksResponsible    TeachingPracticeTrack[]
  teachingPracticeLessonsResponsible   TeachingPracticeLesson[]
  teachingPracticeSignedFormsCollected TeachingPracticeSignedForm[]

  @@map("instructors")
}

model AdminEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_emails")
}

model WeeklySchedule {
  id               String   @id @default(cuid())
  name             String
  startDate        DateTime @db.Date
  endDate          DateTime @db.Date
  uploadedFileName String
  // Controls whether חניכים can see this week yet - lets admins prepare
  // future weeks in advance without exposing them early. Existing rows are
  // backfilled to true at migration time so weeks already live today stay
  // visible; new rows default to false until an admin explicitly publishes.
  isPublished      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items        ScheduleItem[]
  feedbackForm WeeklyFeedbackForm?

  @@index([startDate, endDate])
  @@map("weekly_schedules")
}

// Presence of a row for a date = that date is marked "אין תורנויות ביום זה" -
// the scheduler skips automatic duty generation for it. The course schedule
// itself (ScheduleItem) is unaffected; this only concerns duty generation.
model NoDutyDate {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("no_duty_dates")
}

// Singleton row (id is always 1) tracking the one current course booklet
// PDF. The actual file lives in Supabase Storage (private bucket) at
// storagePath - this row is just metadata, never the file itself.
model CourseBooklet {
  id          Int      @id @default(1)
  fileName    String
  storagePath String
  uploadedAt  DateTime @default(now())
  uploadedBy  String?
  updatedAt   DateTime @updatedAt

  @@map("course_booklet")
}

model ScheduleItem {
  id               String   @id @default(cuid())
  weeklyScheduleId String
  date             DateTime @db.Date
  startTime        String
  endTime          String
  title            String
  description      String?
  groupName        String?
  instructorName   String?
  location         String?
  rawText          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  weeklySchedule WeeklySchedule          @relation(fields: [weeklyScheduleId], references: [id], onDelete: Cascade)
  ridingSlot     RidingSlot?
  ridingSlotLink RidingSlotScheduleItem?

  @@index([date])
  @@map("schedule_items")
}

// Presence of a row = this ScheduleItem is a riding slot - never a field on
// ScheduleItem itself, and never inferred from title/description text (that
// stays a UI-only suggestion elsewhere). Deleting the ScheduleItem cascades
// here, taking its assignments/notes with it.
model RidingSlot {
  id                       String   @id @default(cuid())
  scheduleItemId           String   @unique
  // Deferred to a later stage - default false (hidden) until student
  // visibility is deliberately implemented and enabled per slot.
  showInstructorToStudents Boolean  @default(false)
  showArenaToStudents      Boolean  @default(false)
  showSubgroupToStudents   Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  scheduleItem  ScheduleItem             @relation(fields: [scheduleItemId], references: [id], onDelete: Cascade)
  assignments   RidingSlotAssignment[]
  notes         RidingLessonNote[]
  scheduleItems RidingSlotScheduleItem[]

  @@map("riding_slots")
}

// A logical riding slot can span more than one real ScheduleItem row (e.g. a
// 2-hour lesson stored as two contiguous 1-hour Excel rows, coalesced into
// one display card) - this records every real row a RidingSlot covers,
// including its own anchor row (RidingSlot.scheduleItemId), so instructor
// views/student visibility (later stages) can resolve the full lesson
// instead of only the anchor. One real row belongs to at most one riding
// slot (scheduleItemId unique).
model RidingSlotScheduleItem {
  id             String @id @default(cuid())
  ridingSlotId   String
  scheduleItemId String @unique

  ridingSlot   RidingSlot   @relation(fields: [ridingSlotId], references: [id], onDelete: Cascade)
  scheduleItem ScheduleItem @relation(fields: [scheduleItemId], references: [id], onDelete: Cascade)

  @@unique([ridingSlotId, scheduleItemId])
  @@map("riding_slot_schedule_items")
}

// One row per group/subgroup split within a slot. groupName/subgroupNumber
// both null = applies to the whole slot (no split needed) - a slot with
// different instructors/arenas per subgroup gets one row per split instead.
model RidingSlotAssignment {
  id             String   @id @default(cuid())
  ridingSlotId   String
  groupName      String?
  subgroupNumber Int?
  // Legacy/primary instructor - kept for backward compat during the
  // transition to multi-instructor support (see RidingSlotAssignmentInstructor
  // below). Still written on every save as the first-selected instructor, so
  // any consumer not yet migrated to the join table keeps working.
  instructorId   String?
  arena          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ridingSlot  RidingSlot                       @relation(fields: [ridingSlotId], references: [id], onDelete: Cascade)
  instructor  Instructor?                      @relation(fields: [instructorId], references: [id])
  instructors RidingSlotAssignmentInstructor[]

  @@unique([ridingSlotId, groupName, subgroupNumber])
  @@map("riding_slot_assignments")
}

// Full set of instructors/coaches responsible for one assignment split -
// supersedes RidingSlotAssignment.instructorId as the source of truth going
// forward. That legacy column stays in sync (first-selected instructor) but
// is no longer the only place an assignment's instructor(s) live.
model RidingSlotAssignmentInstructor {
  id                     String   @id @default(cuid())
  ridingSlotAssignmentId String
  instructorId           String
  createdAt              DateTime @default(now())

  assignment RidingSlotAssignment @relation(fields: [ridingSlotAssignmentId], references: [id], onDelete: Cascade)
  instructor Instructor           @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([ridingSlotAssignmentId, instructorId])
  @@map("riding_slot_assignment_instructors")
}

// One row per student per riding slot - a missing row means no note/rating
// entered yet, not a zero/blank rating. Single shared note field (no
// separate admin/instructor tracks) and no history: each save overwrites
// the previous value, same upsert convention as StudentAttendance.
model RidingLessonNote {
  id               String   @id @default(cuid())
  ridingSlotId     String
  studentId        String
  note             String?
  // 1.0-5.0 in 0.5 steps, stored as half-points (2-10) - validated in the
  // action layer, not the schema.
  ratingHalfPoints Int?
  // Overrides the student's normal horse (getHorseDisplayInfo) for display
  // in this specific riding session only - never written back to
  // Student.assignedHorseName/privateHorseName, and has no effect outside
  // this one row.
  sessionHorseName String?
  // Free text, same "grows from whatever gets typed" convention as
  // hayType/concentrateType on HorseFeedingMeal - never a closed list.
  lessonTopic      String?
  updatedByName    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ridingSlot     RidingSlot                      @relation(fields: [ridingSlotId], references: [id], onDelete: Cascade)
  student        Student                         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  taughtStudents RidingLessonNoteTaughtStudent[]

  @@unique([ridingSlotId, studentId])
  @@map("riding_lesson_notes")
}

// Which חניך/ים the note's own trainee (student above) instructed/taught
// during this riding session - a separate student from the note's subject,
// many-to-many since one trainee may teach more than one student in a
// session. Presence of a row = "taught this student"; no row means nothing
// recorded yet, same convention as the rest of this model.
model RidingLessonNoteTaughtStudent {
  id                 String   @id @default(cuid())
  ridingLessonNoteId String
  studentId          String
  createdAt          DateTime @default(now())

  ridingLessonNote RidingLessonNote @relation(fields: [ridingLessonNoteId], references: [id], onDelete: Cascade)
  student          Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([ridingLessonNoteId, studentId])
  @@map("riding_lesson_note_taught_students")
}

// Manager-entered riding progress feedback, separate from RidingLessonNote,
// which is tied to scheduled advanced-instruction sessions. This model is
// NOT per-session and has no relation to ScheduleItem/RidingSlot - the
// manager adds an entry for a trainee's own riding progress whenever she
// wants, not after every riding session. Multiple rows accumulate over time
// per trainee (unlike RidingLessonNote's one-row-per-slot upsert-in-place
// convention), which is why this carries both createdByName and
// updatedByName - a row written by one admin may later be edited by
// another, and each historical entry should still show who originally wrote
// it even after a later edit.
model StudentRidingProgressFeedback {
  id               String   @id @default(cuid())
  studentId        String
  date             DateTime @db.Date
  ratingHalfPoints Int?
  feedback         String?
  horseName        String?
  topic            String?
  createdByName    String?
  updatedByName    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_riding_progress_feedback")
}

// Manager-entered לונג׳ בלי רוכב ("lunge without a rider") progress feedback -
// a standalone journal per trainee, structurally identical to
// StudentRidingProgressFeedback above (same rationale: not per-session, no
// relation to ScheduleItem/RidingSlot, multiple rows accumulate over time,
// both createdByName and updatedByName so an edited row still shows who
// originally wrote it). Deliberately NOT related to TeachingPracticeLesson/
// TeachingPracticeFeedback: a TeachingPracticeLesson with practiceType
// LUNGE is "לונג׳ עם רוכב/ילד" (an admin/instructor generated-lesson
// concept, tracked entirely separately - see that model's own comments) -
// this model is the unrelated, always-manager-entered "לונג׳ בלי רוכב"
// concept the trainee-progress UI keeps in its own top-level section so the
// two are never confused or merged.
model StudentLungeProgressFeedback {
  id               String   @id @default(cuid())
  studentId        String
  date             DateTime @db.Date
  ratingHalfPoints Int?
  feedback         String?
  horseName        String?
  topic            String?
  instructorName   String?
  createdByName    String?
  updatedByName    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_lunge_progress_feedback")
}

enum MessageTaskType {
  MESSAGE
  TASK
}

enum MessageAudience {
  ALL
  GROUP
  SPECIFIC
}

// Recipients are materialized into MessageTaskRecipient rows at send time -
// audience/groupName here are kept only for the admin's own display of what
// was sent, they are never re-queried to determine current recipients.
model MessageTask {
  id            String          @id @default(cuid())
  type          MessageTaskType
  title         String
  body          String
  audience      MessageAudience
  groupName     String?
  createdByName String?
  isArchived    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  recipients MessageTaskRecipient[]

  @@map("message_tasks")
}

model MessageTaskRecipient {
  id            String    @id @default(cuid())
  messageTaskId String
  studentId     String
  readAt        DateTime?
  completedAt   DateTime?
  // Per-trainee archive - separate from MessageTask.isArchived (admin's own
  // global soft-delete/restore). Set only after readAt (MESSAGE) or
  // completedAt (TASK) is already present - enforced in
  // archiveMessageTaskForStudent, never trusted from the client.
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())

  messageTask MessageTask @relation(fields: [messageTaskId], references: [id], onDelete: Cascade)
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([messageTaskId, studentId])
  @@index([studentId])
  @@map("message_task_recipients")
}

enum CourseMaterialType {
  FILE
  LINK
}

enum CourseMaterialVisibility {
  STUDENTS
  INSTRUCTORS
  BOTH
}

// Separate from CourseBooklet on purpose - this supports many rows, each
// with its own storage path, unlike the booklet's singleton fixed-path file.
model CourseMaterial {
  id           String                   @id @default(cuid())
  title        String
  description  String?
  materialType CourseMaterialType
  visibility   CourseMaterialVisibility
  filePath     String?
  fileName     String?
  externalUrl  String?
  isActive     Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@map("course_materials")
}

enum NotificationType {
  ATTENDANCE_MARKED
  MATERIAL_ADDED
}

enum NotificationRecipientRole {
  STUDENT
  INSTRUCTOR
}

// Automatic, system-generated in-app notifications only - deliberately
// separate from MessageTask/MessageTaskRecipient, which stay exactly as they
// are and continue to handle admin/instructor-authored messages and tasks.
// One row per (event, recipient) - studentId is set when recipientRole is
// STUDENT, instructorId when INSTRUCTOR (never both). relatedId is a loose
// pointer to the source row (e.g. a StudentAttendance.id or
// CourseMaterial.id) for a future "open" deep-link - not a real FK, since the
// source table differs by type.
model Notification {
  id            String                    @id @default(cuid())
  type          NotificationType
  title         String
  body          String?
  recipientRole NotificationRecipientRole
  studentId     String?
  instructorId  String?
  relatedId     String?
  readAt        DateTime?
  createdAt     DateTime                  @default(now())

  @@index([studentId])
  @@index([instructorId])
  @@map("notifications")
}

// Web Push subscriptions (VAPID). v1 only ever creates rows with
// recipientRole=STUDENT - instructorId/recipientRole=INSTRUCTOR are modeled
// for shape-consistency with Notification, but nothing subscribes or sends to
// them yet (instructors coordinate over a separate WhatsApp group - see the
// InstructorMessageTaskRecipient revert). endpoint is unique so a browser
// re-subscribing (endpoints rotate periodically) updates in place instead of
// piling up dead rows.
model PushSubscription {
  id            String                    @id @default(cuid())
  recipientRole NotificationRecipientRole
  studentId     String?
  instructorId  String?
  endpoint      String                    @unique
  p256dh        String
  auth          String
  userAgent     String?
  createdAt     DateTime                  @default(now())

  @@index([studentId])
  @@index([instructorId])
  @@map("push_subscriptions")
}

enum WeeklyFeedbackStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum FeedbackQuestionType {
  RATING_5
  COMPARISON_3
  FREE_TEXT
}

enum FeedbackQuestionSource {
  FIXED
  DYNAMIC
}

// One row per week that has ever had a form drafted - at most one per
// WeeklySchedule (weeklyScheduleId unique). Never auto-created; always
// starts from an explicit admin action. Trainee-facing, admin-authored -
// deliberately separate from MessageTask/MessageTaskRecipient, which
// continue to handle admin/instructor-authored messages and tasks.
//
// Availability to trainees is derived, not just status-based: DRAFT is
// never visible; PUBLISHED is only actually open once opensAt is null or in
// the past, and stops accepting submissions once closesAt is in the past;
// CLOSED is closed regardless of either date. publishedAt/closedAt remain
// pure admin-action timestamps (when they clicked publish/close), separate
// from opensAt/closesAt (when it's scheduled to actually open/close for
// trainees) - a form can be published in advance of its own opening.
model WeeklyFeedbackForm {
  id               String               @id @default(cuid())
  weeklyScheduleId String               @unique
  status           WeeklyFeedbackStatus @default(DRAFT)
  title            String
  opensAt          DateTime?
  closesAt         DateTime?
  publishedAt      DateTime?
  closedAt         DateTime?
  createdByName    String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  weeklySchedule WeeklySchedule           @relation(fields: [weeklyScheduleId], references: [id], onDelete: Cascade)
  questions      WeeklyFeedbackQuestion[]
  responses      WeeklyFeedbackResponse[]

  @@map("weekly_feedback_forms")
}

// Questions are materialized onto the form at draft-creation time (fixed
// template copied in, and later - not yet built - schedule-derived dynamic
// ones) - editing the fixed question bank or that week's schedule later
// never retroactively changes an already-drafted form's questions, same
// materialize-at-creation principle as MessageTaskRecipient.
model WeeklyFeedbackQuestion {
  id         String                 @id @default(cuid())
  formId     String
  // Free text (e.g. "אוכל", "מגורים", "רכיבה"), not an enum - matches this
  // schema's existing preference for content-ish fields over a rigid list
  // (see HorseFeedingMeal.hayType).
  section    String
  prompt     String
  type       FeedbackQuestionType
  source     FeedbackQuestionSource
  sortOrder  Int
  isRequired Boolean                @default(true)
  createdAt  DateTime               @default(now())

  form    WeeklyFeedbackForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers WeeklyFeedbackAnswer[]

  @@index([formId])
  @@map("weekly_feedback_questions")
}

// One row = "this trainee submitted" - presence/absence is what drives "who
// responded / who didn't". unique(formId, studentId) is the hard guarantee
// against duplicate submissions (enforced again in the submit action itself,
// never trusted from the client - students have no NextAuth session).
model WeeklyFeedbackResponse {
  id          String   @id @default(cuid())
  formId      String
  studentId   String
  submittedAt DateTime @default(now())

  form    WeeklyFeedbackForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  student Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers WeeklyFeedbackAnswer[]

  @@unique([formId, studentId])
  @@index([studentId])
  @@map("weekly_feedback_responses")
}

// ratingValue is used for RATING_5/COMPARISON_3, textValue for FREE_TEXT -
// validated against the question's type in the action layer, not the schema.
model WeeklyFeedbackAnswer {
  id          String   @id @default(cuid())
  responseId  String
  questionId  String
  ratingValue Int?
  textValue   String?
  createdAt   DateTime @default(now())

  response WeeklyFeedbackResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question WeeklyFeedbackQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([responseId, questionId])
  @@index([questionId])
  @@map("weekly_feedback_answers")
}

enum TeachingPracticeType {
  LUNGE
  BEGINNER_PRIVATE
  BEGINNER_GROUP
}

enum TeachingPracticeRole {
  LEAD_INSTRUCTOR
  SECOND_INSTRUCTOR
  ASSISTANT_INSTRUCTOR
  EVALUATOR
}

// The stable, recurring plan - "this team + these children + this weekly
// time slot" - used only as a template to generate real
// TeachingPracticeLesson rows; never itself shown to trainees. A group
// having two teaching-practice days per week is just two separate tracks
// (each its own weekday/team), not one track spanning two days.
model TeachingPracticeTrack {
  id                             String               @id @default(cuid())
  practiceType                   TeachingPracticeType
  groupName                      String?
  // 0=Sunday..6=Saturday, matches JS Date#getDay() - free-standing hint only,
  // not enforced against actual generated lesson dates.
  weekday                        Int?
  defaultStartTime               String
  defaultEndTime                 String
  defaultLocation                String?
  defaultResponsibleInstructorId String?
  notes                          String?
  // Stops this track being offered as a "generate next lesson" template
  // (e.g. a mid-course team change) without touching lessons already
  // generated from it - same isActive-not-delete convention used elsewhere
  // (Student.isActive, Instructor.isActive, TeachingPracticeChild.isActive).
  isActive                       Boolean              @default(true)
  createdAt                      DateTime             @default(now())
  updatedAt                      DateTime             @updatedAt
  // Only ever set on a BEGINNER_PRIVATE track - the BEGINNER_GROUP track its
  // child eventually joins. Several private tracks can point at the same
  // group track (many private lessons -> one shared group class), which is
  // why this is a plain FK on the "many" side, not a join table.
  groupTrackId                   String?

  defaultResponsibleInstructor Instructor?                    @relation(fields: [defaultResponsibleInstructorId], references: [id])
  trainees                     TeachingPracticeTrackTrainee[]
  children                     TeachingPracticeTrackChild[]
  lessons                      TeachingPracticeLesson[]
  groupTrack                   TeachingPracticeTrack?         @relation("PrivateFeedsGroup", fields: [groupTrackId], references: [id], onDelete: SetNull)
  feedingPrivateTracks         TeachingPracticeTrack[]        @relation("PrivateFeedsGroup")

  @@index([groupTrackId])
  @@map("teaching_practice_tracks")
}

// Ordered team membership - rotationOrder (0,1[,2]) is the position consumed
// by the role-rotation formula, not a display order.
model TeachingPracticeTrackTrainee {
  id            String   @id @default(cuid())
  trackId       String
  traineeId     String
  rotationOrder Int
  createdAt     DateTime @default(now())

  track   TeachingPracticeTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  trainee Student               @relation(fields: [traineeId], references: [id], onDelete: Cascade)

  @@unique([trackId, traineeId])
  @@unique([trackId, rotationOrder])
  @@map("teaching_practice_track_trainees")
}

// Default child(ren) + their default horse/equipment for this track - copied
// (materialized) onto each generated lesson's TeachingPracticeChildAssignment
// at generation time; never read live by an already-generated lesson.
// childId is nullable so horse/equipment can be entered as a placeholder
// before a child is known/chosen yet - a DB-level partial unique index (see
// migration) enforces at most one such childless row per track, since the
// @@unique below (Postgres treats each NULL as distinct) doesn't by itself
// prevent more than one. Generation skips childless rows entirely -
// TeachingPracticeChildAssignment.childId stays required/NOT NULL.
model TeachingPracticeTrackChild {
  id             String   @id @default(cuid())
  trackId        String
  childId        String?
  horseName      String?
  equipmentNotes String?
  createdAt      DateTime @default(now())

  track TeachingPracticeTrack  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  child TeachingPracticeChild? @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([trackId, childId])
  @@map("teaching_practice_track_children")
}

// The concrete occurrence - fully self-contained once generated (own
// date/time/roles/children), so trainee-facing reads never need to touch the
// track. trackId is nullable to still allow a fully ad-hoc one-off lesson
// with no recurring plan behind it. practiceType is denormalized at creation
// time (materialize-at-creation, same principle as WeeklyFeedbackQuestion) -
// editing the track's practiceType later never retroactively changes an
// already-generated lesson.
model TeachingPracticeLesson {
  id                      String               @id @default(cuid())
  trackId                 String?
  practiceType            TeachingPracticeType
  date                    DateTime             @db.Date
  startTime               String
  endTime                 String
  groupName               String?
  location                String?
  responsibleInstructorId String?
  notes                   String?
  isPublished             Boolean              @default(false)
  // Display-only override of the role labels shown in the generated-lessons
  // table's "תפקיד" column for this one lesson, e.g. {"LEAD_INSTRUCTOR":
  // "מדריך 1"} - never read by rotation/assignment/schedule-check/feedback
  // logic, which all keep working off TeachingPracticeParticipant.role.
  // Null/missing key means "use the default ROLE_LABELS text".
  roleLabelOverrides      Json?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  track                 TeachingPracticeTrack?            @relation(fields: [trackId], references: [id])
  responsibleInstructor Instructor?                       @relation(fields: [responsibleInstructorId], references: [id])
  participants          TeachingPracticeParticipant[]
  childAssignments      TeachingPracticeChildAssignment[]

  @@index([date])
  @@map("teaching_practice_lessons")
}

// The flexible per-lesson role table - covers both the 2-role
// (LEAD_INSTRUCTOR/ASSISTANT_INSTRUCTOR) lunge/private rotation and the
// 3-role (LEAD_INSTRUCTOR/SECOND_INSTRUCTOR/EVALUATOR) beginner-group
// rotation with one shape, rather than fixed lead/assistant columns.
model TeachingPracticeParticipant {
  id               String               @id @default(cuid())
  lessonId         String
  traineeId        String
  role             TeachingPracticeRole
  // Marks a role that was hand-changed from what the rotation formula would
  // have produced, so a future "regenerate remaining rotation" tool can
  // skip it - same isManual convention as DutyAssignment.isManual.
  isManualOverride Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  lesson   TeachingPracticeLesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  trainee  Student                   @relation(fields: [traineeId], references: [id], onDelete: Cascade)
  feedback TeachingPracticeFeedback?

  @@unique([lessonId, traineeId])
  @@map("teaching_practice_participants")
}

// External child - explicitly not a Student. isActive (not delete) supports
// mid-course replacement while preserving history on past
// lessons/assignments/feedback references.
model TeachingPracticeChild {
  id               String   @id @default(cuid())
  firstName        String
  lastName         String
  fullName         String
  age              Int?
  gender           String?
  parentName       String?
  parentPhone      String?
  notes            String?
  defaultHorseName String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  trackDefaults TeachingPracticeTrackChild[]
  assignments   TeachingPracticeChildAssignment[]
  signedForms   TeachingPracticeSignedForm[]

  @@map("teaching_practice_children")
}

// One row per child per lesson - materialized from TeachingPracticeTrackChild
// at generation time, then freely editable per occurrence (one-off absence,
// one-week replacement, horse/equipment swap) without touching the track.
model TeachingPracticeChildAssignment {
  id             String   @id @default(cuid())
  lessonId       String
  childId        String
  horseName      String?
  equipmentNotes String?
  isAbsent       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lesson TeachingPracticeLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  child  TeachingPracticeChild  @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([lessonId, childId])
  @@map("teaching_practice_child_assignments")
}

// One row per participant (per trainee-role-in-lesson), never per lesson -
// this is what makes group-lesson feedback separate per trainee/role by
// construction. No history (each save overwrites), same convention as
// RidingLessonNote. v1: never exposed to trainees, admin/authorized-
// instructor-only.
model TeachingPracticeFeedback {
  id               String   @id @default(cuid())
  participantId    String   @unique
  feedback         String?
  ratingHalfPoints Int?
  updatedByName    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  participant TeachingPracticeParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("teaching_practice_feedback")
}

enum TeachingPracticeSignedFormType {
  SAFETY_INSTRUCTIONS
  LUNGE_CONSENT
  BEGINNER_LESSON_CONSENT
}

enum TeachingPracticeSignedFormStatus {
  ACTIVE
  REVOKED
}

// A completed, signed parent-consent record for one TeachingPracticeChild.
// Snapshot-based by design: child*/parent* fields are copied at signing time
// from TeachingPracticeChild and never re-read live afterwards, so a record
// always reflects exactly what the parent saw and signed, even if the
// child's profile changes later. formVersion pins the record to an exact
// entry in lib/parent-signatures/form-definitions.ts (the actual form text
// lives in code, not in the DB - see that file's header) so old signatures
// stay resolvable to their original wording after the form text is next
// updated.
//
// courseCycle (e.g. "2026-summer") is the Stage 1 season boundary: there is
// no dedicated Teaching Practice season/course model yet (CourseSettings is
// a single global row, not scoped per Teaching Practice run), and
// TeachingPracticeChild rows are matched/reused by name+phone across course
// imports (see teaching-practice-child-import.ts), so without this field a
// signature from a past course could otherwise silently satisfy the
// requirement for the same returning child in a future one.
//
// Stage 1: schema/data-model only - no signing UI, no PDF generation, no
// Storage upload writes to this table yet (signatureDataPath/signedPdfPath
// exist now so a later stage can fill them in without another migration).
//
// Re-sign / replacement history: rows are never deleted or overwritten in
// place. Superseding a signature (parent corrects a mistake, or the form
// content version changes) means creating a new row and setting the old
// row's status to REVOKED, preserving full history. A hand-written partial
// unique index (see the migration for this table - Prisma's schema.prisma
// has no syntax for a WHERE-qualified/partial unique index) enforces at most
// one ACTIVE row per (childId, formType, courseCycle); REVOKED rows are
// exempt so history can accumulate freely.
model TeachingPracticeSignedForm {
  id       String                         @id @default(cuid())
  childId  String
  formType TeachingPracticeSignedFormType

  // Stage 1 season boundary - see model comment above. Required (no static
  // schema default makes sense for a value that must track "the current
  // course run"); every write must set it explicitly.
  courseCycle String

  // Snapshots taken at signing time - see model comment above.
  // childNameSnapshot is required (always known at signing); the rest
  // mirror how sparse TeachingPracticeChild itself is (age/parentName/
  // parentPhone are all nullable there too).
  childNameSnapshot   String
  childAgeSnapshot    Int?
  parentNameSnapshot  String?
  parentPhoneSnapshot String?

  // Collected only on this record, never backfilled onto
  // TeachingPracticeChild - mixing parent-self-reported data (address,
  // email, medical disclosures) into the operational child record would
  // conflate two different trust levels/purposes.
  parentEmail  String?
  address      String?
  medicalNotes String?
  photoConsent Boolean?

  signerName String
  // Free text on purpose (e.g. "אב"/"אם"/"אפוטרופוס") rather than an enum -
  // the source forms never constrain this to a fixed list, and a rider aged
  // 18+ signing SAFETY_INSTRUCTIONS for themselves is a real case a small
  // enum would need to special-case anyway.
  signerRole String?

  // Both nullable "for future" per Stage 1 scope - populated by later
  // stages (signature capture, PDF generation); nothing writes to either
  // yet.
  signatureDataPath String?
  signedPdfPath     String?

  // Pins this record to an exact entry in
  // lib/parent-signatures/form-definitions.ts, e.g. "v1". String (not Int)
  // to match that file's .v1/.v2 naming directly.
  formVersion String

  // No DRAFT/pending state in the designed flow (a row is only ever created
  // at the moment of a completed submit), so every row is signed by
  // construction; defaults to creation time like createdAt.
  signedAt DateTime @default(now())

  // Exactly one of collectedByInstructorId / collectedByAdminName is
  // expected to be set in practice (the Stage 1+ tablet flow always sets
  // the instructor; the admin fields exist so a future admin-side
  // collection path doesn't need another migration). Admin identity is
  // denormalized (name/email strings, not an AdminEmail relation) - same
  // "who touched this" convention as StudentAttendance.updatedByName.
  collectedByInstructorId String?
  collectedByAdminEmail   String?
  collectedByAdminName    String?

  status TeachingPracticeSignedFormStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  child                 TeachingPracticeChild @relation(fields: [childId], references: [id], onDelete: Cascade)
  collectedByInstructor Instructor?           @relation(fields: [collectedByInstructorId], references: [id])

  @@index([childId, formType, courseCycle])
  @@map("teaching_practice_signed_forms")
}
